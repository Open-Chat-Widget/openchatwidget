{
  "name": "@openchatwidget/sdk",
  "version": "0.1.1",
  "private": false,
  "description": "Open-source chat widget.",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "build:client": "tsup --config tsup.config.ts --entry widget/src/index.ts --out-dir dist",
    "lint": "eslint widget/src --ext .ts,.tsx --max-warnings=0",
    "format": "prettier --write \"widget/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"widget/src/**/*.{ts,tsx}\""
  },
  "keywords": [
    "ai",
    "chat",
    "widget",
    "openai",
    "vercel-ai-sdk",
    "streaming"
  ],
  "dependencies": {
    "@ai-sdk/openai": "^3.0.30",
    "@ai-sdk/react": "^3.0.99",
    "ai": "^6.0.97",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
