{
  "name": "@openchatwidget/sdk",
  "version": "0.1.1",
  "private": false,
  "description": "Open-source chat widget.",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "style": "dist/index.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite --config sandbox/vite.config.ts --host 127.0.0.1",
    "dev:server": "node --import tsx sandbox/server/index.ts",
    "build": "vite build && node ./scripts/postbuild.mjs && tsc --project tsconfig.build.json",
    "build:client": "vite build",
    "lint": "eslint widget/src --ext .ts,.tsx --max-warnings=0",
    "format": "prettier --write \"widget/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"widget/src/**/*.{ts,tsx}\""
  },
  "keywords": [
    "ai",
    "chat",
    "widget",
    "openai",
    "vercel-ai-sdk",
    "streaming"
  ],
  "dependencies": {
    "@ai-sdk/openai": "^3.0.30",
    "@ai-sdk/react": "^3.0.99",
    "@hono/node-server": "^1.19.11",
    "@mcpjam/sdk": "^0.8.10",
    "ai": "^6.0.97",
    "hono": "^4.12.8",
    "lucide-react": "^0.577.0",
    "react": ">=18",
    "react-dom": ">=18",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.7.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^5.4.11"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
